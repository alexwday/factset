# FactSet API Configuration

# API Key Authentication (simpler to start with)
FACTSET_API_KEY=your_api_key_here

# OAuth2 Authentication (more secure, for production)
FACTSET_CLIENT_ID=your_client_id_here
FACTSET_CLIENT_SECRET=your_client_secret_here

# Base URL for FactSet API
FACTSET_BASE_URL=https://api.factset.com

# Proxy Configuration (for corporate networks)
# Format: http://proxy.company.com:8080 or http://username:password@proxy.company.com:8080
HTTP_PROXY=
HTTPS_PROXY=
# Comma-separated list of hosts to bypass proxy
NO_PROXY=localhost,127.0.0.1