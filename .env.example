# FactSet API Configuration

# API Key Authentication (simpler to start with)
FACTSET_API_KEY=your_api_key_here

# OAuth2 Authentication (more secure, for production)
FACTSET_CLIENT_ID=your_client_id_here
FACTSET_CLIENT_SECRET=your_client_secret_here

# Base URL for FactSet API (v2)
FACTSET_BASE_URL=https://api.factset.com/content